# ScamCheck LT — environment variables
#
# Copy this file to `.env.local` for local development and set a real value.
# `.env.local` is gitignored and must never be committed.

# Admin Panel Lite (v0.3) password.
# Required for /admin and /admin/login. The raw value stays server-side only;
# the browser never receives it. Set the same variable in Vercel project
# settings (Environment Variables) for the deployed environment.
ADMIN_PASSWORD=change-me-to-a-strong-password
