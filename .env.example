# ScamCheck LT — environment variables
#
# Copy this file to `.env.local` for local development and set a real value.
# `.env.local` is gitignored and must never be committed.

# Admin Panel Lite (v0.3) password.
# Required for /admin and /admin/login. The raw value stays server-side only;
# the browser never receives it. Set the same variable in Vercel project
# settings (Environment Variables) for the deployed environment.
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Admin Trend Manager (v0.5) — Supabase ────────────────────────────────────
# OPTIONAL. Without these, the Trend Manager shows a "not configured" state and
# the rest of the app is unaffected (public scam detection does not use these).
#
# Both are SERVER-ONLY secrets. Do NOT prefix them with NEXT_PUBLIC_ — that would
# expose them in client JavaScript. Set the same values in Vercel env vars.
# Setup details: supabase/README.md.
#
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>   # bypasses RLS — keep secret
